RewriteEngine On

# Redirect the former public HTML pages to their clean routes.
RewriteRule ^frontend/index\.html$ /CHICO/ [R=301,L]
RewriteRule ^frontend/login\.html$ /CHICO/login [R=301,L]
RewriteRule ^frontend/registro\.html$ /CHICO/registro [R=301,L]

# Keep public routes canonical so relative module URLs remain stable.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /CHICO/$1 [R=301,L]

# Preserve real assets, Firebase modules and internal view templates.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Every public route is rendered by the single-page application.
RewriteRule ^ index.html [L]
